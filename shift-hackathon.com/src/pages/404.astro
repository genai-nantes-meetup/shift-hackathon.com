---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
---

<Layout title="404 — Page introuvable · Shift Hackathon">
  <Nav client:load />
  <main
    style="min-height:100vh;background:#000;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;font-family:'Barlow',sans-serif;text-align:center;gap:1.5rem;padding:2rem;padding-top:80px;"
  >
    <p style="font-size:7rem;font-weight:900;line-height:1;margin:0;color:#2aebf5;">404</p>
    <p style="font-size:1.25rem;opacity:0.6;margin:0;">Cette page n'existe pas.</p>
    <a
      href="/"
      style="margin-top:1rem;padding:0.75rem 2rem;border:2px solid #2aebf5;color:#2aebf5;text-decoration:none;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;"
    >
      Retour à l'accueil
    </a>
  </main>
</Layout>
