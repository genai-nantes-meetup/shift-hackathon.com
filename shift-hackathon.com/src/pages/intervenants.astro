---
import Layout from '../layouts/Layout.astro';
import SpeakersHero from '../components/intervenants/SpeakersHero';
import SpeakerGrid from '../components/intervenants/SpeakerGrid';
import CTASection from '../components/shared/CTASection';
import { PAGE_META, canonicalFor } from '../data/site';
---

<Layout
  title={PAGE_META.intervenants.title}
  description={PAGE_META.intervenants.description}
  canonical={canonicalFor(PAGE_META.intervenants.path)}
>
  <main style="padding-top: 60px; background: #000; min-height: 100vh; color: #fff;">
    <SpeakersHero client:load />
    <SpeakerGrid client:load />
    <CTASection client:load />
  </main>
</Layout>
