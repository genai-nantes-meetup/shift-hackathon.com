---
import Layout from '../layouts/Layout.astro';
import ConceptHero from '../components/concept/ConceptHero';
import Features from '../components/concept/Features';
import ProjectExamples from '../components/concept/ProjectExamples';
import CTASection from '../components/shared/CTASection';
import Faq from '../components/shared/Faq';
import { FAQ_ITEMS } from '../data/faq';
import { PAGE_META, canonicalFor } from '../data/site';
import { breadcrumbSchema } from '../lib/seo';
---

<Layout
  title={PAGE_META.concept.title}
  description={PAGE_META.concept.description}
  canonical={canonicalFor(PAGE_META.concept.path)}
  faqItems={FAQ_ITEMS}
  jsonLd={[
    breadcrumbSchema([
      { name: 'Accueil', path: '/' },
      { name: 'Concept', path: PAGE_META.concept.path },
    ]),
  ]}
>
  <main style="padding-top: 60px; background: #000; min-height: 100vh; color: #fff;">
    <ConceptHero client:load />
    <Features client:visible />
    <ProjectExamples client:visible />
    <CTASection client:visible />
    <Faq client:visible />
  </main>
</Layout>
