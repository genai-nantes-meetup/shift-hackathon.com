{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/agenda-2026",
      "destination": "/agenda",
      "statusCode": 301
    },
    {
      "source": "/concept-2026",
      "destination": "/concept",
      "statusCode": 301
    },
    {
      "source": "/intervenants-2026",
      "destination": "/intervenants",
      "statusCode": 301
    }
  ]
}